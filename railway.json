{
  "$schema": "https://railway.app/railway.schema.json",

  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "typst"]
        }
      }
    }
  },

  "deploy": {
    "startCommand": "streamlit run Script.py --server.address 0.0.0.0 --server.port $PORT"
  }
}
